; Engine configuration file.
; Godot 4.x — Wixx The Bard (M0 scaffold)

config_version=5

[application]

config/name="Wixx The Bard"
config/description="Guitar-controller 2D platformer (Godot 4, C#)."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.4", "C#", "Forward Plus")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="WixxTheBard"

[autoload]

; The data-driven guitar input layer (M1). Persists across scene changes so
; bindings stay live when the Options screen is opened from play.
GuitarInput="*res://scripts/GuitarInput.cs"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[physics]

; Fixed 60 Hz gameplay step (CLAUDE.md rule 3 / SPEC §14). The /reference movement
; constants are per-tick @ 60 Hz and port 1:1 only while this holds; the Player
; scales per-tick velocity to px/second using this rate.
common/physics_ticks_per_second=60

[input]

; M0 keyboard bindings. The real, remappable data-driven guitar layer lands in M1;
; gameplay code references these named actions, never raw keycodes.
move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194319,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194321,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
